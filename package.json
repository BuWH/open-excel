{
  "name": "open-excel",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "certs:install": "office-addin-dev-certs install",
    "certs:verify": "office-addin-dev-certs verify",
    "dev": "vite",
    "dev:mock": "vite --config vite.config.mock.ts",
    "dev:stop": "lsof -ti :5173 | xargs kill -9 2>/dev/null || echo 'No dev server running on port 5173'",
    "build": "tsc -b && vite build",
    "manifest:validate": "office-addin-manifest validate manifest.xml",
    "lint": "biome check .",
    "format": "biome format --write .",
    "office:serve": "vite --host 0.0.0.0 --port 5173",
    "office:web:start": "office-addin-debugging start manifest.xml web --app excel --no-live-reload --dev-server \"bun run office:serve\"",
    "office:web:stop": "office-addin-debugging stop manifest.xml",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:mock": "playwright test --config playwright.config.mock.ts",
    "e2e:mock:headed": "playwright test --config playwright.config.mock.ts --headed",
    "e2e:step": "node e2e/step.cjs"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.65.2",
    "@mariozechner/pi-ai": "^0.65.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.6",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.0",
    "@types/office-js": "^1.0.420",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "office-addin-debugging": "^6.0.6",
    "office-addin-dev-certs": "^2.0.6",
    "office-addin-manifest": "^2.1.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  }
}
