<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp"
>
  <Id>b6d71685-6a5c-4c0d-9fa4-2f58bb7b1a5d</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Wenhe</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Claude in Excel Rebuild" />
  <Description DefaultValue="Reverse-engineered Excel taskpane prototype powered by LiteLLM." />
  <IconUrl DefaultValue="https://localhost:5173/office/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:5173/office/icon-80.png" />
  <SupportUrl DefaultValue="https://localhost:5173" />
  <AppDomains>
    <AppDomain>https://localhost:5173</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Workbook" />
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:5173/#/" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title" />
            <Description resid="GetStarted.Description" />
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl" />
          </GetStarted>
          <FunctionFile resid="Taskpane.Url" />
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="ClaudeInExcelRebuild.Group">
                <Label resid="GroupLabel" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16" />
                  <bt:Image size="32" resid="Icon.32" />
                  <bt:Image size="80" resid="Icon.80" />
                </Icon>
                <Control xsi:type="Button" id="ClaudeInExcelRebuild.Button">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16" />
                    <bt:Image size="32" resid="Icon.32" />
                    <bt:Image size="80" resid="Icon.80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ClaudeInExcelRebuild.Taskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16" DefaultValue="https://localhost:5173/office/icon-32.png" />
        <bt:Image id="Icon.32" DefaultValue="https://localhost:5173/office/icon-32.png" />
        <bt:Image id="Icon.80" DefaultValue="https://localhost:5173/office/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://localhost:5173/#/" />
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://localhost:5173" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="Claude in Excel Rebuild" />
        <bt:String id="GroupLabel" DefaultValue="Claude Rebuild" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Open Rebuild" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String
          id="GetStarted.Description"
          DefaultValue="Local reverse-engineered Excel agent prototype powered by LiteLLM."
        />
        <bt:String
          id="TaskpaneButton.Tooltip"
          DefaultValue="Open the reverse-engineered Claude in Excel taskpane prototype."
        />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
